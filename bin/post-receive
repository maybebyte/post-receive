use v5.36;
use autodie qw(:all);
use strict;
use warnings;

# Base modules.
use Cwd qw(cwd);
use File::Basename qw(fileparse);
use File::Copy qw(copy move);
use File::Find;
use File::Spec::Functions qw(catdir catfile rootdir);
use File::Temp qw(tempdir);
use Getopt::Std;
use IO::Compress::Gzip qw(gzip $GzipError);
use IPC::Open3;

# External modules.
use IPC::System::Simple qw(capturex systemx);

our $opt_v;

my $GZIP_SIZE_THRESHOLD_BYTES = 1400;
my $GZIP_ELIGIBLE_FILE_RE = qr/\.(?:html|css|txt|xml|asc|svg)\z/;
my $WEBSITE_ROOT_GZIP_SRC_POLICY = 'no-src';

sub check_dependencies {
	my $which_output = capturex qw(which --), @_;
	$which_output = undef;
}

# The website_md branch invokes ssg6 and rssg via absolute HOME/.local/bin
# paths, so the PATH-based check_dependencies probe cannot catch them. Run
# this guard after build_hook_context but before any destructive work so a
# missing helper fails fast with a clear path instead of corrupting the
# webroot mid-run. Other branches stay out: dotfiles installs the helpers in
# place, and sysadm/learning_perl_exercises never invoke them.
sub check_repository_helper_dependencies {
	my ($context) = @_;

	return
		unless $context->{repo_name_no_dot_git} eq
		$context->{website_repo_name};

	for my $helper ( $context->{bin_ssg}, $context->{bin_rssg} ) {
		-x $helper
			or die
			"Required website helper missing or not executable: $helper\n";
	}
}

sub parse_options {
	getopts('v');
	return $opt_v;
}

sub build_hook_context {
	my $repo_location = cwd;
	my $repo_name = fileparse $repo_location;
	my $repo_name_no_dot_git = $repo_name =~ s/\.git\z//r;

	my $home = $ENV{'HOME'} // ( getpwuid $< )[7];
	my $bindir = catdir $home, qw(.local bin);

	# Keep website and dotfiles helper resolution pinned to HOME/.local/bin.
	# website_md executes these absolute paths directly, and dotfiles later
	# replaces the same targets in place. The harness contains this behavior by
	# swapping HOME, not by teaching the hook to discover alternate helpers on
	# PATH.
	my $bin_ssg = catdir $bindir, 'ssg6';
	my $bin_rssg = catdir $bindir, 'rssg';

	my $owner = 'Ashlen';
	my $domain_with_schema = 'https://www.anthes.is';
	my $domain_without_schema = $domain_with_schema =~ s{\A[a-z]+://}{}r;
	my $website_name = 'anthesis';
	my $website_title = "My Unix blog: scripts, software, /etc - $website_name";

	# Production historically publishes straight into /var/www/htdocs/<domain>.
	# The harness contains that host-path assumption via
	# POST_RECEIVE_WEB_SERVER_DIR instead of changing the fallback itself.
	my $web_server_dir = $ENV{'POST_RECEIVE_WEB_SERVER_DIR'}
		// catfile( rootdir(), qw(var www htdocs), $domain_without_schema );

	my ( $src_dir, $src_page ) = qw(src src.html);
	my $clone_url =
		$domain_with_schema . "/$src_dir/$repo_name_no_dot_git/.git";
	my $stagit_dir = catdir $web_server_dir, $src_dir, $repo_name_no_dot_git;

	my $website_repo_name = 'website_md';
	my $sysadm_repo_name = 'sysadm';
	my $dotfiles_repo_name = 'dotfiles';
	my $learning_perl_repo_name = 'learning_perl_exercises';

	my %repo_descriptions = (
		$website_repo_name => "Source for $domain_without_schema",
		$sysadm_repo_name => 'System Administration Tools',
		$dotfiles_repo_name => 'OpenBSD configuration files',
		$learning_perl_repo_name => 'Learning Perl exercises',
	);

	return {
		repo_location => $repo_location,
		repo_name => $repo_name,
		repo_name_no_dot_git => $repo_name_no_dot_git,
		home => $home,
		bindir => $bindir,
		bin_ssg => $bin_ssg,
		bin_rssg => $bin_rssg,
		owner => $owner,
		domain_with_schema => $domain_with_schema,
		domain_without_schema => $domain_without_schema,
		website_name => $website_name,
		website_title => $website_title,
		web_server_dir => $web_server_dir,
		src_dir => $src_dir,
		src_page => $src_page,
		clone_url => $clone_url,
		stagit_dir => $stagit_dir,
		website_repo_name => $website_repo_name,
		sysadm_repo_name => $sysadm_repo_name,
		dotfiles_repo_name => $dotfiles_repo_name,
		learning_perl_repo_name => $learning_perl_repo_name,
		repo_descriptions => \%repo_descriptions,
	};
}

sub log_hook_context {
	my ($context) = @_;

	my @entries = (
		[ 'REPOSITORY LOCATION', $context->{repo_location} ],
		[ 'REPOSITORY NAME', $context->{repo_name} ],
		[ 'REPOSITORY NAME (sans .git)', $context->{repo_name_no_dot_git} ],
		[ 'HOME DIRECTORY', $context->{home} ],
		[ 'BINARY DIRECTORY', $context->{bindir} ],
		[ 'SSG LOCATION', $context->{bin_ssg} ],
		[ 'RSSG LOCATION', $context->{bin_rssg} ],
		[ 'OWNER', $context->{owner} ],
		[ 'DOMAIN WITH SCHEMA', $context->{domain_with_schema} ],
		[ 'DOMAIN WITHOUT SCHEMA', $context->{domain_without_schema} ],
		[ 'WEBSITE NAME', $context->{website_name} ],
		[ 'WEBSITE TITLE', $context->{website_title} ],
		[ 'WEB SERVER DIRECTORY', $context->{web_server_dir} ],
		[ 'SRC DIRECTORY NAME', $context->{src_dir} ],
		[ 'SRC PAGE NAME', $context->{src_page} ],
		[ 'CLONE URL', $context->{clone_url} ],
		[ 'STAGIT DIRECTORY', $context->{stagit_dir} ],
		[ 'WEBSITE REPOSITORY NAME', $context->{website_repo_name} ],
		[ 'SYSADM REPOSITORY NAME', $context->{sysadm_repo_name} ],
		[ 'DOTFILES REPOSITORY NAME', $context->{dotfiles_repo_name} ],
		[
			'LEARNING PERL REPOSITORY NAME',
			$context->{learning_perl_repo_name}
		],
		[
			'WEBSITE DESCRIPTION',
			$context->{repo_descriptions}{ $context->{website_repo_name} }
		],
		[
			'SYSADM DESCRIPTION',
			$context->{repo_descriptions}{ $context->{sysadm_repo_name} }
		],
		[
			'DOTFILES DESCRIPTION',
			$context->{repo_descriptions}{ $context->{dotfiles_repo_name} }
		],
		[
			'LEARNING PERL DESCRIPTION',
			$context->{repo_descriptions}
				{ $context->{learning_perl_repo_name} }
		],
	);

	for my $entry (@entries) {
		my ( $label, $value ) = @{$entry};
		say "$label: $value" if $opt_v;
	}
}

# File::Find passes traversal state through globals, so wrap the real worker
# with the hook context and any mode flags it needs.
sub build_find_wanted_callback {
	my ( $sub, @bound_args ) = @_;
	return sub { $sub->( @bound_args, @_ ); };
}

sub gzip_files {
	my ( $context, $src_policy ) = @_;
	$src_policy //= '';

	# Preserve the existing cheap-path ordering: skip obvious non-candidates
	# before statting anything on disk.
	#
	# The .git exclusion intentionally matches against the full visited path, so
	# anything under a .git path is left alone even if it otherwise looks like a
	# publishable asset.
	return if $File::Find::name =~ /\.git/;
	return unless $_ =~ $GZIP_ELIGIBLE_FILE_RE;

	if ( $src_policy eq $WEBSITE_ROOT_GZIP_SRC_POLICY ) {
		if ( $File::Find::name =~ /$context->{src_dir}/ ) {

			# Preserve the intentionally narrow website rule: during the webroot
			# gzip pass, paths containing src are skipped unless the basename is
			# exactly src.html. That keeps src/src.html compressed while siblings
			# such as src/other.html stay uncompressed.
			return unless $_ eq $context->{src_page};
		}
	}

	return unless -f;

	# Preserve the strict threshold behavior: files must be larger than 1400
	# bytes. A file at exactly 1400 bytes does not get a gzip sidecar.
	return unless ( -s _ ) > $GZIP_SIZE_THRESHOLD_BYTES;

	gzip $_ => "$_.gz" or die "gzipping $_ to $_.gz failed: $GzipError\n";
}

sub clone_repo_to_tempdir {
	my ($context) = @_;

	say "Creating temporary directory for $context->{repo_name_no_dot_git}"
		if $opt_v;
	my $clone_dir = tempdir( CLEANUP => 1 );

	say "Running 'git clone -- $context->{repo_location} $clone_dir'" if $opt_v;
	systemx qw(git clone --), $context->{repo_location}, $clone_dir;

	return $clone_dir;
}

sub clone_website_source_to_tempdir {
	my ($context) = @_;
	return clone_repo_to_tempdir($context);
}

sub run_website_ssg {
	my ( $context, $clone_dir ) = @_;

	say
		"Running '$context->{bin_ssg} $clone_dir $context->{web_server_dir} $context->{website_name} "
		. "$context->{domain_with_schema}'"
		if $opt_v;

	# Preserve the odd subprocess wiring here: stderr is passed straight
	# through, stdout is left on a pipe, and the pipe is only closed after the
	# child exits. The harness characterizes the resulting files and exit
	# status, not a cleaner stream contract.
	my $ssg_pid = open3(
		undef, my $ssg_out,
		'>&STDERR', $context->{bin_ssg},
		$clone_dir, $context->{web_server_dir},
		$context->{website_name}, $context->{domain_with_schema}
	) or die "Could not open ssg: $!\n";

	waitpid $ssg_pid, 0;

	# NOTE: This MUST come after waitpid; otherwise, ssg won't generate
	# the website.
	close $ssg_out;
}

sub write_website_rss_feed {
	my ( $context, $clone_dir ) = @_;

	my $rss_file_path = catdir $context->{web_server_dir}, 'rss.xml';
	say "RSS FEED LOCATION: $rss_file_path" if $opt_v;

	my $rssg_index_name = 'index.md';
	say "INDEX NAME FOR RSSG: $rssg_index_name" if $opt_v;

	my $rssg_index_location = catfile $clone_dir, $rssg_index_name;
	say "INDEX LOCATION FOR RSSG: $rssg_index_location" if $opt_v;

	say
		"Running '$context->{bin_rssg} $rssg_index_location $context->{website_title}'"
		if $opt_v;

	# NOTE: rssg hangs if its STDOUT is redirected straight to a file handle,
	# so preserve the pipe-drain-to-file pattern here. STDERR still goes
	# directly to STDERR so child failures surface the same way as before.
	my $rssg_pid =
		open3( undef, my $rssg_out, '>&STDERR', $context->{bin_rssg},
			$rssg_index_location, $context->{website_title} )
		or die "Could not open rssg: $!\n";

	open my $rss_feed_fh, '>', $rss_file_path;
	while (<$rssg_out>) { print $rss_feed_fh $_; }

	waitpid $rssg_pid, 0;

	# Keep the historical wait-then-close order after draining stdout;
	# changing it has hung rssg before.
	close $rssg_out;
	close $rss_feed_fh;
}

sub list_top_level_entries {
	my (%args) = @_;

	my $directory = $args{directory}
		or die "list_top_level_entries requires directory\n";
	my $skip_name = $args{skip_name};

	opendir( my $directory_fh, $directory );
	my @entries;
	while ( my $file = readdir $directory_fh ) {
		next if $file eq '.';
		next if $file eq '..';
		next if $skip_name && $skip_name->($file);
		push @entries, catfile( $directory, $file );
	}
	closedir $directory_fh;

	return @entries;
}

sub resolve_sysadm_target_dir {
	my ($context) = @_;

	# Preserve the contained deployment seam: callers can override the
	# default /etc/sysadm target without changing the repo-name match.
	# Production still falls back to the real host path; the harness uses
	# POST_RECEIVE_SYSADM_DIR so characterization runs never touch /etc.
	return $ENV{'POST_RECEIVE_SYSADM_DIR'} // catdir &rootdir, 'etc',
		$context->{sysadm_repo_name};
}

sub clear_sysadm_target_dir {
	my ($sysadm_dir) = @_;

	# Preserve the longstanding contract that the deployment target already
	# exists; this branch clears it in place instead of recreating it.
	say "Clearing out $sysadm_dir" if $opt_v;
	my @files_to_delete = list_top_level_entries( directory => $sysadm_dir );
	systemx qw(rm -rf --), @files_to_delete;
}

sub move_sysadm_clone_into_target {
	my ( $clone_dir, $sysadm_dir ) = @_;

	say "Moving the appropriate files to $sysadm_dir" if $opt_v;
	my @files_to_copy = list_top_level_entries(
		directory => $clone_dir,
		skip_name => sub { $_[0] eq '.git' },
	);
	systemx qw(mv -f --), @files_to_copy, $sysadm_dir;
}

sub run_sysadm_action {
	my ($context) = @_;

	my $clone_dir = clone_repo_to_tempdir($context);
	my $sysadm_dir = resolve_sysadm_target_dir($context);
	say "SYSADM DIRECTORY: $sysadm_dir" if $opt_v;

	clear_sysadm_target_dir($sysadm_dir);
	move_sysadm_clone_into_target( $clone_dir, $sysadm_dir );
}

sub replace_dotfiles_ssg6_helper {
	my ( $context, $clone_dir ) = @_;

	my $clone_ssg = catdir $clone_dir, qw(.local bin ssg);
	say "Replacing $context->{bin_ssg} with newer $clone_ssg" if $opt_v;

	# Preserve the historical rename from the repo's .local/bin/ssg source
	# to the installed HOME/.local/bin/ssg6 target.
	move $clone_ssg, $context->{bin_ssg};
}

sub replace_dotfiles_rssg_helper {
	my ( $context, $clone_dir ) = @_;

	my $clone_rssg = catdir $clone_dir, qw(.local bin rssg);
	say "Replacing $context->{bin_rssg} with newer $clone_rssg" if $opt_v;
	move $clone_rssg, $context->{bin_rssg};
}

sub chmod_dotfiles_helpers {
	my ($context) = @_;

	say
		"Changing permissions for $context->{bin_ssg} and $context->{bin_rssg} to 700"
		if $opt_v;
	chmod 0700, $context->{bin_ssg}, $context->{bin_rssg};
}

sub run_dotfiles_action {
	my ($context) = @_;

	# Preserve the historical absolute helper targets under HOME/.local/bin,
	# even though the dotfiles repo still provides .local/bin/ssg and rssg.
	# The harness contains this by pointing HOME at a temp tree, not by
	# renaming the installed targets.
	my $clone_dir = clone_repo_to_tempdir($context);

	replace_dotfiles_ssg6_helper( $context, $clone_dir );
	replace_dotfiles_rssg_helper( $context, $clone_dir );
	chmod_dotfiles_helpers($context);
}

sub clone_repo_into_stagit_git_dir {
	my ($context) = @_;

	my $stagit_git_dir = catdir $context->{stagit_dir}, '.git';
	say "STAGIT GIT DIRECTORY: $stagit_git_dir" if $opt_v;

	say
		"Running 'git clone --bare -- $context->{repo_location} $stagit_git_dir'"
		if $opt_v;
	systemx qw(git clone --bare --), $context->{repo_location}, $stagit_git_dir;

	return $stagit_git_dir;
}

sub update_stagit_git_server_info {
	my ( $context, $stagit_git_dir ) = @_;

	say "Running 'git update-server-info' for $context->{repo_name_no_dot_git}"
		if $opt_v;
	chdir $stagit_git_dir;
	systemx qw(git update-server-info);
}

sub render_repository_with_stagit {
	my ($context) = @_;

	say "Running 'stagit -- $context->{repo_location}'" if $opt_v;
	chdir $context->{stagit_dir};
	systemx qw(stagit --), $context->{repo_location};
}

sub publish_repository_with_stagit {
	my ($context) = @_;

	my $stagit_git_dir = clone_repo_into_stagit_git_dir($context);
	update_stagit_git_server_info( $context, $stagit_git_dir );
	render_repository_with_stagit($context);
}

sub write_owner_metadata {
	my (%args) = @_;

	unless ( eval {
		open my $repo_owner_fh, '>',
			catfile( $args{repo_location}, 'owner' );
		say $repo_owner_fh $args{owner};
		close $repo_owner_fh;
		say "Populated owner metadata for $args{repo_name_no_dot_git}"
			if $opt_v;
	} )
	{
		print STDERR "Couldn't write to $args{repo_location}/owner $@" if $@;
	}
}

sub write_description_metadata {
	my (%args) = @_;

	unless ( eval {
		open my $repo_description_fh, '>',
			catfile( $args{repo_location}, 'description' );
		say $repo_description_fh $args{repo_descriptions}
			{ $args{repo_name_no_dot_git} };
		close $repo_description_fh;
		say "Populated description metadata for $args{repo_name_no_dot_git}"
			if $opt_v;
	} )
	{
		print STDERR "Couldn't write to $args{repo_location}/description: $@"
			if $@;
	}
}

sub write_url_metadata {
	my (%args) = @_;

	unless ( eval {
		open my $repo_url_fh, '>', catfile( $args{repo_location}, 'url' );
		say $repo_url_fh $args{clone_url};
		close $repo_url_fh;
		say "Populated URL metadata for $args{repo_name_no_dot_git}"
			if $opt_v;
	} )
	{
		print STDERR "Couldn't write to $args{repo_location}/url: $@" if $@;
	}
}

sub write_repository_metadata {
	my (%args) = @_;

	write_owner_metadata(%args);
	write_description_metadata(%args);
	write_url_metadata(%args);
}

sub write_metadata_from_context {
	my ($context) = @_;

	write_repository_metadata(
		repo_location => $context->{repo_location},
		repo_name_no_dot_git => $context->{repo_name_no_dot_git},
		owner => $context->{owner},
		clone_url => $context->{clone_url},
		repo_descriptions => $context->{repo_descriptions},
	);
}

sub prepare_stagit_directory {
	my ($context) = @_;

	say "Clearing out $context->{stagit_dir}" if $opt_v;
	systemx qw(rm -rf --), $context->{stagit_dir};

	say "Creating $context->{stagit_dir}" if $opt_v;
	systemx qw(mkdir -p --), $context->{stagit_dir};
}

sub clear_website_root_preserving_src {
	my ($context) = @_;

	say
		"Clearing out $context->{web_server_dir} (excluding $context->{src_dir})"
		if $opt_v;

	# Website generation rewrites the site root, but src/ must survive so
	# sibling repo pages stay available until the shared tail refreshes this
	# repo's own src/<name> directory.
	opendir( my $web_server_dir_fh, $context->{web_server_dir} );
	my @files_to_delete;
	while ( my $file = readdir $web_server_dir_fh ) {
		next if $file eq '.';
		next if $file eq '..';
		next if $file eq $context->{src_dir};
		$file = catdir $context->{web_server_dir}, $file;
		push @files_to_delete, $file;
	}
	closedir $web_server_dir_fh;
	systemx qw(rm -rf --), @files_to_delete;
}

sub delete_website_files_marker {
	my ($context) = @_;

	my $dot_files_file = catdir $context->{web_server_dir}, '.files';
	say "Deleting $dot_files_file" if $opt_v;

	# ssg6 leaves a bookkeeping marker at the webroot that should never be
	# part of the published site.
	unlink $dot_files_file;
}

sub gzip_website_root_output {
	my ($context) = @_;

	say
		"Gzipping files in $context->{web_server_dir} (excluding those in $context->{src_dir})"
		if $opt_v;
	find build_find_wanted_callback( \&gzip_files, $context,
		$WEBSITE_ROOT_GZIP_SRC_POLICY ),
		$context->{web_server_dir};
}

sub run_website_md_action {
	my ($context) = @_;

	clear_website_root_preserving_src($context);
	my $clone_dir = clone_website_source_to_tempdir($context);
	run_website_ssg( $context, $clone_dir );
	write_website_rss_feed( $context, $clone_dir );
	delete_website_files_marker($context);
	gzip_website_root_output($context);
}

sub build_repository_action_dispatch {
	my ($context) = @_;

	return {
		$context->{website_repo_name} => \&run_website_md_action,
		$context->{sysadm_repo_name} => \&run_sysadm_action,
		$context->{dotfiles_repo_name} => \&run_dotfiles_action,
	};
}

sub run_repository_specific_actions {
	my ($context) = @_;

	# Repositories not listed here skip special-case handling and fall
	# straight through to the final shared stagit publishing phase.
	my $repo_actions = build_repository_action_dispatch($context);
	my $repo_action = $repo_actions->{ $context->{repo_name_no_dot_git} }
		or return;

	$repo_action->($context);
}

sub build_shared_stagit_asset_copy_plan {
	my ($context) = @_;

	my $shared_stagit_asset_dir =
		catdir( $context->{web_server_dir}, 'stagit' );

	return (
		{
			label => 'CSS',
			source => catfile( $shared_stagit_asset_dir, 'style.css' ),
			destination => catfile( $context->{stagit_dir}, 'style.css' ),
		},
		{
			label => 'logo',
			source => catfile( $shared_stagit_asset_dir, 'logo.png' ),
			destination => catfile( $context->{stagit_dir}, 'logo.png' ),
		},
		{
			label => 'favicon',
			source => catfile( $shared_stagit_asset_dir, 'favicon.png' ),
			destination => catfile( $context->{stagit_dir}, 'favicon.png' ),
		},
	);
}

sub copy_shared_stagit_assets {
	my ($context) = @_;

	my ( $stagit_log, $stagit_index ) = (
		catfile( $context->{stagit_dir}, 'log.html' ),
		catfile( $context->{stagit_dir}, 'index.html' )
	);

	say "Copying $stagit_log to $stagit_index" if $opt_v;
	copy $stagit_log, $stagit_index;

	my @shared_stagit_asset_copy_plan =
		build_shared_stagit_asset_copy_plan($context);

	for my $copy_step (@shared_stagit_asset_copy_plan) {
		my ( $label, $source, $destination ) =
			@{$copy_step}{qw(label source destination)};
		say "Copying $label from $source to $destination" if $opt_v;
		copy $source, $destination;
	}
}

sub gzip_stagit_publish_output {
	my ($context) = @_;

	say "Gzipping files in $context->{stagit_dir}" if $opt_v;
	find build_find_wanted_callback( \&gzip_files, $context ),
		$context->{stagit_dir};
}

sub run_final_stagit_publish_phase {
	my ($context) = @_;

	publish_repository_with_stagit($context);
	copy_shared_stagit_assets($context);
	gzip_stagit_publish_output($context);
}

sub run_post_receive_hook {
	my @dependencies = qw(stagit git);

	check_dependencies @dependencies;
	parse_options();

	my $context = build_hook_context();
	log_hook_context($context);

	check_repository_helper_dependencies($context);

	write_metadata_from_context($context);
	prepare_stagit_directory($context);
	run_repository_specific_actions($context);
	run_final_stagit_publish_phase($context);
}

run_post_receive_hook();
